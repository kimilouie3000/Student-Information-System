@model Department
@{ ViewData["Title"] = "Create Department"; }
<h1>Create Department</h1>
<form asp-action="Create"><div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"/><span asp-validation-for="Name" class="text-danger"></span></div>
<div class="mb-3"><label asp-for="Description" class="form-label"></label><input asp-for="Description" class="form-control"/><span asp-validation-for="Description" class="text-danger"></span></div>
<button type="submit" class="btn btn-primary">Save</button> <a asp-action="Index">Back</a></form>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
