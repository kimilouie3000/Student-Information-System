@model Course
<h1>Course Details</h1>
<dl class="row"><dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.Name</dd><dt class="col-sm-2">Duration</dt><dd class="col-sm-10">@Model.DurationInMonths</dd><dt class="col-sm-2">Department</dt><dd class="col-sm-10">@Model.Department?.Name</dd></dl>
<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> | <a asp-action="Index">Back</a>
