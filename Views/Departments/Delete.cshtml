@model Department
@{ ViewData["Title"] = "Delete Department"; }
<h1>Delete Department</h1>
<p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
<form asp-action="Delete"><input type="hidden" asp-for="Id"/><button type="submit" class="btn btn-danger">Delete</button> <a asp-action="Index">Cancel</a></form>
