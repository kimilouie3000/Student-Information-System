@model IEnumerable<Course>
@{ ViewData["Title"] = "Courses"; }
<h1>Courses</h1><p><a asp-action="Create" class="btn btn-primary">Create New</a></p>
<table class="table"><thead><tr><th>Name</th><th>Duration</th><th>Department</th><th></th></tr></thead><tbody>
@foreach (var item in Model) {
<tr><td>@item.Name</td><td>@item.DurationInMonths</td><td>@item.Department?.Name</td><td><a asp-action="Edit" asp-route-id="@item.Id">Edit</a> | <a asp-action="Details" asp-route-id="@item.Id">Details</a> | <a asp-action="Delete" asp-route-id="@item.Id">Delete</a></td></tr>}
</tbody></table>
