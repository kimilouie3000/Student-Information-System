@model Department
@{ ViewData["Title"] = "Department Details"; }
<h1>Department Details</h1>
<dl class="row"><dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.Name</dd><dt class="col-sm-2">Description</dt><dd class="col-sm-10">@Model.Description</dd></dl>
<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> | <a asp-action="Index">Back</a>
