@model Instructor
<h1>Instructor Details</h1>
<dl class="row"><dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.FullName</dd><dt class="col-sm-2">Email</dt><dd class="col-sm-10">@Model.Email</dd><dt class="col-sm-2">Department</dt><dd class="col-sm-10">@Model.Department?.Name</dd></dl>
<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> | <a asp-action="Index">Back</a>
